{
  "lsp": {
    "deno": {
      "settings": {
        "deno": {
          "enable": true
        }
      }
    },
    "emmet-language-server": {
      "initialization_options": {
        "includeLanguages": {
          "vento": "html"
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["deno"],
      "formatter": "language_server"
    },
    "TypeScript": {
      "language_servers": ["deno"],
      "formatter": "language_server"
    },
    "TSX": {
      "language_servers": ["deno"],
      "formatter": "language_server"
    },
    "Vento": {
      "language_servers": ["emmet-language-server"]
    }
  }
}
